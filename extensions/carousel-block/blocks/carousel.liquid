{%- assign slides_json = "[" -%}
{%- assign first_slide = true -%}

{%- for i in (1..12) -%}
  {%- assign img_key = "slide_" | append: i | append: "_image" -%}
  {%- assign title_key = "slide_" | append: i | append: "_title" -%}
  {%- assign desc_key = "slide_" | append: i | append: "_description" -%}
  {%- assign btn_key = "slide_" | append: i | append: "_button_text" -%}
  {%- assign link_key = "slide_" | append: i | append: "_link_url" -%}

  {%- assign img = block.settings[img_key] | default: section.settings[img_key] -%}
  {%- assign title = block.settings[title_key] | default: section.settings[title_key] -%}
  {%- assign desc = block.settings[desc_key] | default: section.settings[desc_key] -%}
  {%- assign btn = block.settings[btn_key] | default: section.settings[btn_key] -%}
  {%- assign link = block.settings[link_key] | default: section.settings[link_key] -%}

  {%- if img != blank or title != blank -%}
    {%- capture slide_item -%}
      {
        "id": "slide{{ i }}",
        "imageUrl": {% if img != blank %}"{{ img | image_url: width: 800 }}"{% else %}""{% endif %},
        "title": "{{ title | escape }}",
        "description": "{{ desc | escape }}",
        "buttonText": "{{ btn | escape }}",
        "linkUrl": "{{ link | default: "#" }}"
      }
    {%- endcapture -%}
    {%- if first_slide == false -%}{%- assign slides_json = slides_json | append: "," -%}{%- endif -%}
    {%- assign slides_json = slides_json | append: slide_item -%}
    {%- assign first_slide = false -%}
  {%- endif -%}
{%- endfor -%}

{%- assign slides_json = slides_json | append: "]" -%}

{%- assign design_setting = block.settings.design | default: section.settings.design | default: "3" -%}
{%- assign design_num = design_setting | plus: 0 -%}
{%- assign center_scale_raw = block.settings.center_scale | default: section.settings.center_scale | default: 112 -%}
{%- assign center_scale_val = center_scale_raw | times: 1.0 | divided_by: 100.0 -%}
{%- assign max_w = block.settings.container_max_width | default: 1200 -%}

{%- capture settings_json -%}
  {
    "design": {{ design_num }},
    "appearance": {
      "backgroundColor": "{{ block.settings.background_color | default: section.settings.background_color | default: '#ffffff' }}",
      "borderRadius": {{ block.settings.border_radius | default: section.settings.border_radius | default: 16 }},
      "fontFamily": "Inter"
    },
    "layout": {
      "visibleCards": {{ block.settings.visible_cards | default: section.settings.visible_cards | default: 3 }},
      "gap": {{ block.settings.gap | default: section.settings.gap | default: 24 }},
      "rotationAngle": {{ block.settings.rotation_angle | default: section.settings.rotation_angle | default: 42 }},
      "centerScale": {{ center_scale_val }},
      "depthSpacing": {{ block.settings.depth_spacing | default: section.settings.depth_spacing | default: 200 }},
      "cardWidth": {{ block.settings.card_width | default: section.settings.card_width | default: 300 }},
      "showReflection": {{ block.settings.show_reflection | default: section.settings.show_reflection | default: false }}
    },
    "navigation": {
      "arrows": {{ block.settings.arrows | default: section.settings.arrows | default: false }},
      "dots": {{ block.settings.dots | default: section.settings.dots | default: false }},
      "autoplay": {{ block.settings.autoplay | default: section.settings.autoplay | default: false }}
    }
  }
{%- endcapture -%}

<div class="carousel-craft-embed" 
     style="max-width: {{ max_w }}px; margin: 0 auto;"
     data-shop="{{ shop.permanent_domain }}" 
     data-customizer-settings='{{ settings_json }}'
     data-customizer-slides='{{ slides_json }}'>
  <!-- Loading state -->
  <div class="carousel-craft-loading" style="text-align: center; padding: 2rem 0; color: #9ca3af; font-family: sans-serif;">
    Loading Carousel...
  </div>
</div>

